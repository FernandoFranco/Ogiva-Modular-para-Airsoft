# EditorConfig - Configuração de estilo de código
# https://editorconfig.org

root = true

# Padrões para todos os arquivos
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Arquivos C/C++
[*.{c,cpp,h,hpp,ino}]
indent_style = space
indent_size = 2

# Arquivos JSON
[*.{json,jsonc}]
indent_style = space
indent_size = 2

# Arquivos Markdown
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

# Arquivos INI (platformio.ini)
[*.ini]
indent_style = space
indent_size = 2

# Arquivos YAML
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Makefiles
[Makefile]
indent_style = tab
